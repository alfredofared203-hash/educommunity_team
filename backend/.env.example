# ===== EduCommunity Backend — مثال متغيرات البيئة =====
# انسخ هذا الملف إلى .env واملأ القيم

PORT=5000
NODE_ENV=development

# قاعدة البيانات (MongoDB)
MONGODB_URI=mongodb://127.0.0.1:27017/educommunity

# رابط الفرونت (للـCORS في الإنتاج)
CLIENT_URL=http://localhost:8080

# JWT — استخدم نصوص عشوائية طويلة في الإنتاج
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# رفع الملفات
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Cloudinary (اختياري) — اتركها فارغة للتخزين المحلي في /uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
